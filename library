function Library:CreateWindow(parent, title, size, position)
    print("Creating window:", title)
    
    local window = Instance.new("Frame")
    window.Name = title .. "Window"
    window.Size = size or UDim2.new(0, self:ScaleX(62), 0, self:ScaleY(88))
    window.Position = position or UDim2.new(0, self:ScaleX(7), 0.5, -self:ScaleY(44))
    window.BackgroundColor3 = self.Colors.Background
    window.BackgroundTransparency = 0.2
    window.BorderSizePixel = 0
    window.Parent = parent
    window.Active = true
    window.ClipsDescendants = false
    
    self:AddCorner(window, 8)
    self:AddStroke(window, 1, self.Colors.BorderLight)
    
    local titleBar = Instance.new("Frame")
    titleBar.Name = "TitleBar"
    titleBar.Size = UDim2.new(1, -20, 0, self:ScaleY(6))
    titleBar.Position = UDim2.new(0, 10, 0, 5)
    titleBar.BackgroundTransparency = 1
    titleBar.Parent = window
    
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "Title"
    titleLabel.Size = UDim2.new(1, -50, 1, 0)
    titleLabel.Position = UDim2.new(0, 10, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextColor3 = self.Colors.AccentLight
    titleLabel.Font = self.Fonts.Bold
    titleLabel.TextSize = self:ScaleY(2)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = titleBar
    
    print("✓ Window created:", title)
    return window
end

function Library:CreateMinimizeButton(parent, targetWindow)
    print("Creating minimize button")
    
    local btn = Instance.new("TextButton")
    btn.Name = "MinimizeButton"
    btn.Size = UDim2.new(0, self:ScaleX(4.5), 0, self:ScaleY(5.5))
    btn.Position = UDim2.new(1, -self:ScaleX(6), 0, self:ScaleY(2))
    btn.BackgroundColor3 = self.Colors.Accent
    btn.Text = "−"
    btn.TextColor3 = self.Colors.Text
    btn.Font = self.Fonts.Bold
    btn.TextSize = self:ScaleY(2.5)
    btn.Parent = parent
    btn.AutoButtonColor = false
    btn.ZIndex = 10
    
    self:AddCorner(btn, 4)
    
    local minimized = false
    btn.MouseButton1Click:Connect(function()
        minimized = not minimized
        targetWindow.Visible = not minimized
        btn.Text = minimized and "□" or "−"
        print(minimized and "Window minimized" or "Window restored")
    end)
    
    local function updatePos()
        btn.Position = UDim2.new(1, -self:ScaleX(6), 0, self:ScaleY(2))
    end
    camera:GetPropertyChangedSignal("ViewportSize"):Connect(updatePos)
    
    print("✓ Minimize button created")
    return btn
end

function Library:MakeDraggable(frame, handle)
    if not frame then return end
    handle = handle or frame
    
    local dragging = false
    local dragStart
    local startPos
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    
    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

