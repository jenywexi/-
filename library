    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -self:ScaleX(0.8), 0, self:ScaleY(5.5))
    btn.Position = UDim2.new(0, self:ScaleX(0.4), 0, (index-1) * self:ScaleY(6))
    btn.BackgroundColor3 = isSelected and self.Colors.Selected or baseColor
    btn.Text = towerName
    btn.TextColor3 = self.Colors.Text
    btn.TextSize = self:ScaleY(1.6)
    btn.Font = self.Fonts.Normal
    btn.Parent = parent
    btn.AutoButtonColor = false
    
    self:AddCorner(btn, 3)
    self:AddStroke(btn, 1, self.Colors.Border)
    
    if callback then
        btn.MouseButton1Click:Connect(function()
            pcall(function() callback(btn, towerName, baseColor) end)
        end)
    end
    
    return btn
end

