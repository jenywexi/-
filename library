function Library:CreateTabs(parent, tabs)
    print("Creating tabs:", #tabs)
    
    local tabs = tabs or {"Tab1", "Tab2", "Tab3"}
    local tabButtons = {}
    local tabContents = {}
    local activeTab = nil
    
    local tabWidth = (parent.AbsoluteSize.X - self:ScaleX(4)) / #tabs
    
    for i, tabName in ipairs(tabs) do
        local btn = self:CreateButton(
            parent,
            tabName:upper(),
            UDim2.new(0, tabWidth - self:ScaleX(1), 0, self:ScaleY(5.5)),
            UDim2.new(0, self:ScaleX(1) + ((i-1) * (tabWidth + self:ScaleX(1))), 0, self:ScaleY(1)),
            i == 1 and self.Colors.Accent or self.Colors.BackgroundLight
        )
        tabButtons[tabName] = btn
    end
    
    print("✓ Tabs created")
    return tabButtons
end

function Library:CreateTowerButton(parent, towerName, index, isSelected, callback)
    if not parent then return nil end
    
    local isEven = index % 2 == 0
