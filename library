function Library:CreateToggleButton(parent, text, defaultState, size, position, callback)
    if not parent then return nil, defaultState end
    
    local btn = Instance.new("TextButton")
    btn.Size = size or UDim2.new(0, self:ScaleX(8), 0, self:ScaleY(4))
    btn.Position = position or UDim2.new(0, 0, 0, 0)
    btn.BackgroundColor3 = defaultState and self.Colors.Success or self.Colors.BackgroundLight
    btn.Text = text .. (defaultState and " ✓" or " ✗")
    btn.TextColor3 = self.Colors.Text
    btn.Font = self.Fonts.Bold
    btn.TextSize = self:ScaleY(1.4)
    btn.Parent = parent
    btn.AutoButtonColor = false
    
    self:AddCorner(btn, 4)
    
    local state = defaultState
    
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.BackgroundColor3 = state and self.Colors.Success or self.Colors.BackgroundLight
        btn.Text = text .. (state and " ✓" or " ✗")
        if callback then
            pcall(function() callback(state) end)
        end
    end)
    
    return btn, state
end

function Library:CreateMiniToggleRow(parent, buttons)
    if not parent then return nil, {} end
    
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -self:ScaleX(2), 0, self:ScaleY(6))
    row.Position = UDim2.new(0, self:ScaleX(1), 0, 0)
    row.BackgroundTransparency = 1
    row.Parent = parent
    
    local toggles = {}
    local buttonWidth = 0.19
    
    for i, data in ipairs(buttons) do
        local xPos = buttonWidth * (i-1) + (0.01 * (i-1))
        local btn, state = self:CreateToggleButton(
            row, 
            data.name, 
            data.default,
            UDim2.new(buttonWidth, 0, 1, 0),
            UDim2.new(xPos, 0, 0, 0),
            data.callback
        )
        toggles[data.name] = {button = btn, state = state}
    end
    
    return row, toggles
end

function Library:ClearContainer(container)
    if not container then return end
    for _, child in ipairs(container:GetChildren()) do
        child:Destroy()
    end
end


return Library
