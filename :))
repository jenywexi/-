local function SetupEquipmentListener()
    local StateReplicators = ReplicatedStorage:FindFirstChild("StateReplicators")
    if StateReplicators then
        local function onEquipmentChanged()
            task.wait(0.2)
            for i = 1, 5 do
                if not (lastSelectedSlot == i) then
                    slotFilled[i] = false
                    slotNames[i] = ""
                    slotButtons[i].BackgroundColor3 = Library.Colors.BackgroundLight
                    slotButtons[i].Text = "[EMPTY]"
                    slotButtons[i].TextColor3 = Library.Colors.TextDim
                end
            end
            AssignEquippedTowersToSlots()
        end

        for _, folder in ipairs(StateReplicators:GetChildren()) do
            if folder.Name == "PlayerReplicator" and folder:GetAttribute("UserId") == player.UserId then
                folder:GetAttributeChangedSignal("EquippedTowers"):Connect(onEquipmentChanged)
            end
        end

        StateReplicators.ChildAdded:Connect(function(newFolder)
            task.wait(0.1)
            if newFolder.Name == "PlayerReplicator" and newFolder:GetAttribute("UserId") == player.UserId then
                newFolder:GetAttributeChangedSignal("EquippedTowers"):Connect(onEquipmentChanged)
            end
        end)
    end
end

