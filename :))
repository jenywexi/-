local function getWorldPositionPrecise(screenPosition)
    if isMobile then
        if terrain then
            local success, pos = pcall(function()
                return terrain:GetMousePosition(Camera, screenPosition)
            end)
            if success and pos then
                return pos.X, pos.Y + 2, pos.Z
            end
        end

        local ray = Camera:ScreenPointToRay(screenPosition.X, screenPosition.Y)
        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
        raycastParams.FilterDescendantsInstances = {player.Character, Camera}
        raycastParams.IgnoreWater = true

        local raycastResult = Workspace:Raycast(ray.Origin, ray.Direction * 1000, raycastParams)
        if raycastResult then
            local hitPoint = raycastResult.Position
            return hitPoint.X, hitPoint.Y + 2, hitPoint.Z
        end

        local directions = {
            ray.Direction,
            Vector3.new(ray.Direction.X, ray.Direction.Y - 0.1, ray.Direction.Z),
            Vector3.new(ray.Direction.X, ray.Direction.Y + 0.1, ray.Direction.Z)
        }
        for _, dir in ipairs(directions) do
            local fallbackResult = Workspace:Raycast(ray.Origin, dir * 1000, raycastParams)
            if fallbackResult then
                return fallbackResult.Position.X, fallbackResult.Position.Y + 2, fallbackResult.Position.Z
            end
        end
        return nil, nil, nil
    else
        local ray = Camera:ViewportPointToRay(screenPosition.X, screenPosition.Y)
        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
        raycastParams.FilterDescendantsInstances = {player.Character, Camera}
        raycastParams.IgnoreWater = true

        local raycastResult = Workspace:Raycast(ray.Origin, ray.Direction * 1000, raycastParams)
        if raycastResult then
            local hitPoint = raycastResult.Position
            return hitPoint.X, hitPoint.Y + 5, hitPoint.Z
        end

        local directions = {
            ray.Direction,
            Vector3.new(ray.Direction.X, ray.Direction.Y - 0.05, ray.Direction.Z),
            Vector3.new(ray.Direction.X, ray.Direction.Y + 0.05, ray.Direction.Z)
        }
        for _, dir in ipairs(directions) do
            local fallbackResult = Workspace:Raycast(ray.Origin, dir * 1000, raycastParams)
            if fallbackResult then
                return fallbackResult.Position.X, fallbackResult.Position.Y + 5, fallbackResult.Position.Z
            end
        end
        return nil, nil, nil
    end
end

local function placeTowerAtPosition(towerName, x, y, z)
    if not towerName or not x or not z then 
        return false, "Invalid parameters"
    end
    local placeY = (y or 80) + 5
    local success, result = pcall(function()
        return RemoteFunction:InvokeServer("Troops", "Place", {
            Rotation = CFrame.new(),
            Position = Vector3.new(x, placeY, z)
        }, towerName)
    end)
    if success then
        return true, result
    else
        return false, result
    end
end

