local function send_request(url, body)
    if type(http) == "table" and type(http.request) == "function" then
        return http.request({
            Url = url,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = body
        })
    end
    return HttpService:PostAsync(url, body, Enum.HttpContentType.ApplicationJson, false, {["Content-Type"] = "application/json"})
end

