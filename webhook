local function tdx_get_reward_text(keyword)
    local direct = tdx_get_text("Interface.GameOverScreen.Main.RewardsFrame.InnerFrame." .. keyword)
    if direct ~= "" then return direct end
    local withLabel = tdx_get_text("Interface.GameOverScreen.Main.RewardsFrame.InnerFrame." .. keyword .. ".TextLabel")
    if withLabel ~= "" then return withLabel end

    local rewardsFrame = tdx_get_object("Interface.GameOverScreen.Main.RewardsFrame")
    if rewardsFrame then
        for _, child in ipairs(rewardsFrame:GetDescendants()) do
            if child:IsA("TextLabel") and child.Text then
                if string.find(string.lower(child.Text), string.lower(keyword)) then
                    return child.Text
                end
            end
        end
    end

    local gameOverScreen = tdx_get_object("Interface.GameOverScreen")
    if gameOverScreen then
        for _, child in ipairs(gameOverScreen:GetDescendants()) do
            if child:IsA("TextLabel") and child.Text then
                if string.find(string.lower(child.Text), string.lower(keyword)) then
                    return child.Text
                end
            end
        end
    end

    return ""
end

